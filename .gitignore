# Dependencies
node_modules/

# Next.js build output
.next/
**/.next/

# Build outputs
dist/
build/
**/dist/
**/build/

# Test artifacts
test-results/
playwright-report/
**/test-results/
**/playwright-report/

# DOCX export artifacts (Milestone 3A).
# Exports are generated in memory and streamed to the user on demand. We
# never commit a generated .docx — if a future Playbook ever ships a binary
# template, allowlist it explicitly with a `!path/to/template.docx` line.
*.docx
**/*.docx

# Cover email Markdown export artifacts (Milestone 3B).
# Only the renderer-generated suffix is ignored; ordinary docs like
# README.md, CLAUDE.md, docs/*.md remain tracked.
*_cover_email.md
**/*_cover_email.md

# Environment / secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db