# ContractOps AI — environment configuration template.
#
# Copy to .env.local (or your environment manager of choice). NEVER commit a
# .env file containing real secrets. NEVER paste real confidential source
# documents into anything you plan to send through real-mode (USE_REAL_LLM=true).

# ─────────────────────────────────────────────────────────────────────────
# Server-side flags (read by Node: CLI, vitest, Next API routes).
# ─────────────────────────────────────────────────────────────────────────

# Master real-mode switch. Default: false. Mock mode remains the default; even
# with API keys present, USE_REAL_LLM=false ALWAYS yields the mock provider.
USE_REAL_LLM=false

# OpenAI: real provider for the Deal Memo drafter only (Milestone 2C scope).
OPENAI_API_KEY=
# Optional: override the model id. Defaults to gpt-4o-mini in createOpenAIProvider.
OPENAI_MODEL=

# Anthropic: real provider for the counterparty_reviewer role (Milestone 2E).
ANTHROPIC_API_KEY=
# Optional: override the model id. Defaults to claude-3-5-sonnet-20241022 in
# createAnthropicProvider.
ANTHROPIC_MODEL=

# Reserved for future milestones — NOT consumed by any provider yet.
GOOGLE_API_KEY=

# Comma-separated allowlist of real provider ids. Real mode REFUSES to start
# unless the provider is on the list. Supported in 2E: "openai", "anthropic".
LLM_PROVIDER_ALLOWLIST=

# Debug: echo rendered prompts to stderr. Default false. Never enable in a
# real-mode session against confidential text.
LLM_LOG_PROMPTS=false

# ─────────────────────────────────────────────────────────────────────────
# Client-side flags (visible to the browser — DO NOT put secrets here).
# Next.js inlines anything prefixed with NEXT_PUBLIC_ at build time.
# ─────────────────────────────────────────────────────────────────────────

# Display badge in the header. Default "MOCK" — set to "OPENAI" (or similar)
# when running a real-mode build so users know which backend is active.
NEXT_PUBLIC_LLM_MODE=MOCK
NEXT_PUBLIC_LLM_PROVIDER_ID=mock

# Tells the browser whether to escalate any agent role from mock to a real
# provider (via the matching server-side /api/agent/<role> route). Must
# mirror the server-side USE_REAL_LLM and LLM_PROVIDER_ALLOWLIST values for
# the wiring to work.
NEXT_PUBLIC_USE_REAL_LLM=false
NEXT_PUBLIC_LLM_PROVIDER_ALLOWLIST=
# Build-time hints for the model ids shown in the Agent Runs panel.
NEXT_PUBLIC_OPENAI_MODEL=
NEXT_PUBLIC_ANTHROPIC_MODEL=

# ─────────────────────────────────────────────────────────────────────────
# Persistence driver (Milestone 3E).
#   memory (default) — in-process Map. State lost on every server restart.
#                      Used by CI and by default `npm run dev`.
#   file             — durable local dev. State stored as JSON + JSONL
#                      under PERSISTENCE_FILE_PATH (default
#                      ".contractops-data/"). NOT production-grade —
#                      no auth, no encryption, no replication.
# Any other value is rejected at boot (no silent fallback).
# ─────────────────────────────────────────────────────────────────────────
PERSISTENCE_DRIVER=memory
PERSISTENCE_FILE_PATH=.contractops-data

# ─────────────────────────────────────────────────────────────────────────
# Optional: gated end-to-end test against the real OpenAI Deal Memo drafter.
# CI must leave this unset. Local runs:
#     E2E_REAL_OPENAI=true USE_REAL_LLM=true OPENAI_API_KEY=sk-... \
#       LLM_PROVIDER_ALLOWLIST=openai \
#       NEXT_PUBLIC_USE_REAL_LLM=true NEXT_PUBLIC_LLM_PROVIDER_ALLOWLIST=openai \
#       npm run e2e -w @contractops/web
# ─────────────────────────────────────────────────────────────────────────
E2E_REAL_OPENAI=false

# ─────────────────────────────────────────────────────────────────────────
# Optional: gated durable-persistence Playwright spec (Milestone 3E). CI
# must leave this unset. Local runs require all three of these vars:
#     E2E_DURABLE_PERSISTENCE=true \
#       PERSISTENCE_DRIVER=file \
#       PERSISTENCE_FILE_PATH=.tmp-e2e-data \
#       npm run e2e -w @contractops/web
# ─────────────────────────────────────────────────────────────────────────
E2E_DURABLE_PERSISTENCE=false
