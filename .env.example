# ContractOps AI — environment configuration template.
#
# Copy to .env.local (or your environment manager of choice). NEVER commit a
# .env file containing real secrets. NEVER paste real confidential source
# documents into anything you plan to send through real-mode (USE_REAL_LLM=true).

# ─────────────────────────────────────────────────────────────────────────
# Server-side flags (read by Node: CLI, vitest, Next API routes).
# ─────────────────────────────────────────────────────────────────────────

# Master real-mode switch. Default: false. Mock mode remains the default; even
# with API keys present, USE_REAL_LLM=false ALWAYS yields the mock provider.
USE_REAL_LLM=false

# OpenAI: real provider for the Deal Memo drafter only (Milestone 2C scope).
OPENAI_API_KEY=
# Optional: override the model id. Defaults to gpt-4o-mini in createOpenAIProvider.
OPENAI_MODEL=

# Anthropic: real provider for the counterparty_reviewer role (Milestone 2E).
ANTHROPIC_API_KEY=
# Optional: override the model id. Defaults to claude-3-5-sonnet-20241022 in
# createAnthropicProvider.
ANTHROPIC_MODEL=

# Reserved for future milestones — NOT consumed by any provider yet.
GOOGLE_API_KEY=

# Comma-separated allowlist of real provider ids. Real mode REFUSES to start
# unless the provider is on the list. Supported in 2E: "openai", "anthropic".
LLM_PROVIDER_ALLOWLIST=

# Debug: echo rendered prompts to stderr. Default false. Never enable in a
# real-mode session against confidential text.
LLM_LOG_PROMPTS=false

# ─────────────────────────────────────────────────────────────────────────
# Client-side flags (visible to the browser — DO NOT put secrets here).
# Next.js inlines anything prefixed with NEXT_PUBLIC_ at build time.
# ─────────────────────────────────────────────────────────────────────────

# Display badge in the header. Default "MOCK" — set to "OPENAI" (or similar)
# when running a real-mode build so users know which backend is active.
NEXT_PUBLIC_LLM_MODE=MOCK
NEXT_PUBLIC_LLM_PROVIDER_ID=mock

# Tells the browser whether to escalate any agent role from mock to a real
# provider (via the matching server-side /api/agent/<role> route). Must
# mirror the server-side USE_REAL_LLM and LLM_PROVIDER_ALLOWLIST values for
# the wiring to work.
NEXT_PUBLIC_USE_REAL_LLM=false
NEXT_PUBLIC_LLM_PROVIDER_ALLOWLIST=
# Build-time hints for the model ids shown in the Agent Runs panel.
NEXT_PUBLIC_OPENAI_MODEL=
NEXT_PUBLIC_ANTHROPIC_MODEL=

# ─────────────────────────────────────────────────────────────────────────
# Persistence driver (Milestones 3E + 3H).
#   memory (default) — in-process Map. State lost on every server restart.
#                      Used by CI and by default `npm run dev`.
#   file             — durable local dev. State stored as JSON + JSONL
#                      under PERSISTENCE_FILE_PATH (default
#                      ".contractops-data/"). NOT production-grade —
#                      no auth, no encryption, no replication.
#   postgres         — durable, multi-process. State stored in a real
#                      PostgreSQL instance (Milestone 3H). Requires
#                      DATABASE_URL. Production deployment still
#                      requires real authentication + project-level
#                      authorization on top — Postgres fixes durability
#                      and concurrency, not identity (see ADR-015).
# Any other value is rejected at boot (no silent fallback).
# ─────────────────────────────────────────────────────────────────────────
PERSISTENCE_DRIVER=memory
PERSISTENCE_FILE_PATH=.contractops-data

# ─────────────────────────────────────────────────────────────────────────
# PostgreSQL adapter (Milestone 3H). Read ONLY when
# PERSISTENCE_DRIVER=postgres. Missing / empty DATABASE_URL throws
# PostgresConfigError at boot — there is no silent fallback to memory.
# NEVER commit a real DATABASE_URL. Local example:
#   DATABASE_URL=postgres://contractops:contractops@localhost:5432/contractops
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL=
# "true" / "1" / "yes" / "on" enables TLS with rejectUnauthorized:false,
# suitable for managed providers (Supabase, Neon, RDS). Anything else =
# no TLS. For hardened deployments, swap createPgPool to pass a real CA.
POSTGRES_SSL=false

# ─────────────────────────────────────────────────────────────────────────
# Optional: gated end-to-end test against the real OpenAI Deal Memo drafter.
# CI must leave this unset. Local runs:
#     E2E_REAL_OPENAI=true USE_REAL_LLM=true OPENAI_API_KEY=sk-... \
#       LLM_PROVIDER_ALLOWLIST=openai \
#       NEXT_PUBLIC_USE_REAL_LLM=true NEXT_PUBLIC_LLM_PROVIDER_ALLOWLIST=openai \
#       npm run e2e -w @contractops/web
# ─────────────────────────────────────────────────────────────────────────
E2E_REAL_OPENAI=false

# ─────────────────────────────────────────────────────────────────────────
# Optional: gated durable-persistence Playwright spec (Milestone 3E). CI
# must leave this unset. Local runs require all three of these vars:
#     E2E_DURABLE_PERSISTENCE=true \
#       PERSISTENCE_DRIVER=file \
#       PERSISTENCE_FILE_PATH=.tmp-e2e-data \
#       npm run e2e -w @contractops/web
# ─────────────────────────────────────────────────────────────────────────
E2E_DURABLE_PERSISTENCE=false

# ─────────────────────────────────────────────────────────────────────────
# Optional: gated PostgreSQL integration test (Milestone 3H). CI must
# leave this unset. The test in
# packages/web/tests/persistence-postgres-integration.test.ts runs only
# when BOTH of these are set, and it calls `resetDemoStore()` against
# the target DB — point ONLY at a disposable dev/staging instance.
#     POSTGRES_INTEGRATION=true \
#       DATABASE_URL=postgres://user:pass@host:5432/db \
#       POSTGRES_SSL=false \
#       npm run test -w @contractops/web
# ─────────────────────────────────────────────────────────────────────────
POSTGRES_INTEGRATION=false

# ─────────────────────────────────────────────────────────────────────────
# Authentication boundary (Milestones 3I + 3J).
#   demo (default)   — cookie-based DemoSessionAuthProvider from 3I.
#                       Hardcoded actor registry, no password, no token.
#                       Pre-auth seam for local/mock development.
#   signed_cookie    — HMAC-signed session cookie backed by a user
#                       store with PBKDF2 password hashes (3J).
#                       Real-auth seam — still NOT production-grade:
#                       no OAuth/SSO, no rate limiting, no MFA, no
#                       per-project RBAC. See ADR-017.
#
# Production deployment refuses AUTH_MODE=demo unless
# ALLOW_DEMO_AUTH_IN_PRODUCTION=true is also set (dev override only).
# ─────────────────────────────────────────────────────────────────────────
AUTH_MODE=demo

# ─────────────────────────────────────────────────────────────────────────
# Signed-cookie auth secret (Milestone 3J). Required when
# AUTH_MODE=signed_cookie. Must be at least 32 characters of entropy.
# Generate with: openssl rand -base64 48
# NEVER commit a real value.
# ─────────────────────────────────────────────────────────────────────────
AUTH_SESSION_SECRET=

# Optional session cookie tunables. Defaults shown.
AUTH_COOKIE_NAME=contractops_session
AUTH_COOKIE_MAX_AGE_SECONDS=604800

# DEMO_AUTH_ENABLED — default true in AUTH_MODE=demo, false in
# AUTH_MODE=signed_cookie. Setting to "true" in signed_cookie mode
# re-enables POST /api/auth/demo/actor for dev convenience; do NOT
# enable in production.
DEMO_AUTH_ENABLED=

# Production demo override — refuse-by-default guard. Setting this
# to "true" in NODE_ENV=production allows AUTH_MODE=demo to boot
# (otherwise readAuthConfig throws DemoAuthInProductionError).
ALLOW_DEMO_AUTH_IN_PRODUCTION=false

# ─────────────────────────────────────────────────────────────────────────
# Optional: gated signed-cookie auth Playwright spec (Milestone 3J).
# CI must leave this unset. Also enables the dev-only
# POST /api/auth/dev/seed route that pre-creates the three sanitized
# demo users for the gated spec. Local run:
#     E2E_SIGNED_AUTH=true \
#       AUTH_MODE=signed_cookie \
#       AUTH_SESSION_SECRET=$(openssl rand -base64 48) \
#       npm run e2e -w @contractops/web -- signed-auth.spec.ts
# ─────────────────────────────────────────────────────────────────────────
E2E_SIGNED_AUTH=false

# ─────────────────────────────────────────────────────────────────────────
# Auth / security event log (Milestone 3K).
#
# The auth boundary now emits append-only events for login_success /
# login_failed / logout / session_invalid / session_expired /
# session_tampered / demo_actor_switch / demo_auth_forbidden. The
# events are kept in an in-process MemoryAuthEventStore (NOT a
# production SIEM — see ADR-018 for the migration path).
#
# Setting AUTH_EVENTS_INSPECT=true exposes a dev-only inspect route:
#     GET /api/auth/events  → { events: AuthEvent[] }
# CI must leave this unset. Local + the gated signed-auth-events
# Playwright spec enable it explicitly. Production deployment must
# forward events to a real SIEM and keep this route disabled.
# ─────────────────────────────────────────────────────────────────────────
AUTH_EVENTS_INSPECT=false
